{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/plants",
      "destination": "/api/plants"
    },
    {
      "source": "/api/weather",
      "destination": "/api/weather"
    },
    {
      "source": "/api/calculate",
      "destination": "/api/calculate"
    },
    {
      "source": "/api/geo",
      "destination": "/api/geo"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
